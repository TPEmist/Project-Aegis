# ── BYOC: Bring Your Own Card (stored locally, never exposed to AI) ──
AEGIS_BYOC_NUMBER=           # 16-digit card number, no spaces
AEGIS_BYOC_EXP_MONTH=        # Expiry month, e.g. 04
AEGIS_BYOC_EXP_YEAR=         # Expiry year, e.g. 31
AEGIS_BYOC_CVV=              # 3-digit security code

# ── Billing information (used by agent to fill billing fields) ──
AEGIS_BILLING_FIRST_NAME=
AEGIS_BILLING_LAST_NAME=
AEGIS_BILLING_STREET=
AEGIS_BILLING_ZIP=
AEGIS_BILLING_EMAIL=

# ── Payment policy ──
AEGIS_ALLOWED_CATEGORIES=["wikipedia", "donation", "aws", "cloudflare"]
AEGIS_MAX_PER_TX=50.0
AEGIS_MAX_DAILY=100.0
AEGIS_BLOCK_LOOPS=true

# ── CDP injection settings (Hacker Edition) ──
# Requires Chrome launched with --remote-debugging-port=9222 before use.
# macOS: "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
#         --remote-debugging-port=9222 --user-data-dir=/tmp/chrome-aegis-profile
AEGIS_AUTO_INJECT=true
AEGIS_CDP_URL=http://localhost:9222

# ── Optional: LLM Guardrail (default is keyword mode) ──
# AEGIS_GUARDRAIL_ENGINE=llm
# AEGIS_LLM_API_KEY=sk-...
# AEGIS_LLM_BASE_URL=http://localhost:11434/v1
# AEGIS_LLM_MODEL=gpt-4o-mini

# ── Optional: Stripe Enterprise Edition ──
# AEGIS_STRIPE_KEY=sk_live_...
