# ── BYOC: Bring Your Own Card (stored locally, never exposed to AI) ──
POP_BYOC_NUMBER=           # 16-digit card number, no spaces
POP_BYOC_EXP_MONTH=        # Expiry month, e.g. 04
POP_BYOC_EXP_YEAR=         # Expiry year, e.g. 31
POP_BYOC_CVV=              # 3-digit security code

# ── Billing information (used by agent to fill billing fields) ──
POP_BILLING_FIRST_NAME=
POP_BILLING_LAST_NAME=
POP_BILLING_STREET=
POP_BILLING_ZIP=
POP_BILLING_EMAIL=

# ── Payment policy ──
POP_ALLOWED_CATEGORIES=["wikipedia", "donation", "aws", "cloudflare"]
POP_MAX_PER_TX=50.0
POP_MAX_DAILY=100.0
POP_BLOCK_LOOPS=true

# ── CDP injection settings (Hacker Edition) ──
# Requires Chrome launched with --remote-debugging-port=9222 before use.
# macOS: "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
#         --remote-debugging-port=9222 --user-data-dir=/tmp/chrome-pop-profile
POP_AUTO_INJECT=true
POP_CDP_URL=http://localhost:9222

# ── Optional: LLM Guardrail (default is keyword mode) ──
# POP_GUARDRAIL_ENGINE=llm
# POP_LLM_API_KEY=sk-...
# POP_LLM_BASE_URL=http://localhost:11434/v1
# POP_LLM_MODEL=gpt-4o-mini

# ── Optional: Stripe Enterprise Edition ──
# POP_STRIPE_KEY=sk_live_...
